      "text": "Bien nommer mes ficher, dossier, classes :",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bien nommer mes ficher, dossier, classes :",
      "autoResize": true,
