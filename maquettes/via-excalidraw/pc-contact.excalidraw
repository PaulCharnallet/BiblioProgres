    {
      "id": "FTP4YVXM45aDNiQyEJi4N",
      "type": "text",
      "x": 1605.1027875627792,
      "y": 2159.297546386719,
      "width": 383.39971923828125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
